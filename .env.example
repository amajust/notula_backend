# Gladia.io API
GLADIA_API_KEY=your_gladia_api_key_here

# Webhooks & Real-time
BASE_URL=https://your-ngrok-url.ngrok-free.dev
RECALL_WEBHOOK_SECRET=your_recall_webhook_secret_here
